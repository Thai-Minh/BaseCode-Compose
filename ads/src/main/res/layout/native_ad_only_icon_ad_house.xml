<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:id="@+id/native_icon_bound"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_centerInParent="true"
        app:cardBackgroundColor="#0000"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <com.zenith.adapter.ui.MediaView
            android:id="@+id/native_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@id/native_icon_bound"
        android:layout_alignTop="@id/native_icon_bound"
        android:layout_marginStart="-6dp"
        android:layout_marginTop="-3dp"
        android:paddingHorizontal="3dp"
        android:background="@drawable/bg_logo_ad"
        android:text="@string/ad"
        android:textAllCaps="true"
        android:textColor="#60BF00"
        android:textSize="8dp" />

    <com.looper.ads.ui.TransparentButton
        android:id="@+id/native_call_to_action"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?selectableItemBackground" />
</RelativeLayout>