<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#171717"
        android:padding="10dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/native_icon_group"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="visible"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#222222"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/native_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#222222"
                android:scaleType="fitCenter" />
        </androidx.cardview.widget.CardView>


        <View
            android:id="@+id/native_headline"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/common_grey_border_8_bg"
            app:layout_constraintBottom_toTopOf="@id/native_body"
            app:layout_constraintEnd_toStartOf="@id/native_call_to_action"
            app:layout_constraintStart_toEndOf="@id/native_icon_group"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/native_body"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/common_grey_border_8_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/native_headline"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="@+id/native_headline"
            app:layout_constraintTop_toBottomOf="@+id/native_headline" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/native_call_to_action"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/common_button_oval"
            android:fontFamily="@font/sf_pro_medium"
            android:paddingHorizontal="20dp"
            android:includeFontPadding="false"
            android:text="Open"
            android:textColor="@color/white"
            android:textSize="13dp"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.facebook.shimmer.ShimmerFrameLayout>