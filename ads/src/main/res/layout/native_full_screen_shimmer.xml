<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#141414">

        <com.zenith.adapter.ui.AdvertiserView
            android:id="@+id/native_sponsored_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            app:attribution_src="@drawable/ic_ad_top_left"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/native_icon_group"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:layout_constraintBottom_toBottomOf="@id/native_body"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/native_headline"
            app:layout_constraintVertical_bias="0.5">

            <View
                android:id="@+id/native_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0DFFFFFF"
                android:scaleType="fitCenter" />
        </androidx.cardview.widget.CardView>

        <View
            android:id="@+id/native_headline"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="80dp"
            android:background="@drawable/common_grey_border_8_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/native_icon_group"
            app:layout_constraintTop_toBottomOf="@id/native_sponsored_layout" />

        <View
            android:id="@+id/native_body"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/common_grey_border_8_bg"
            app:layout_constraintEnd_toEndOf="@+id/native_headline"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="@+id/native_headline"
            app:layout_constraintTop_toBottomOf="@+id/native_headline" />

        <View
            android:id="@+id/native_media_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:background="#0DFFFFFF"
            app:layout_constraintBottom_toTopOf="@id/native_call_to_action"
            app:layout_constraintTop_toBottomOf="@id/native_body" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/native_call_to_action"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/ripple_round_button_gradient"
            android:elevation="0dp"
            android:fontFamily="@font/sf_pro_medium"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="110dp"
            android:paddingHorizontal="16dp"
            android:stateListAnimator="@null"
            android:text="Open"
            android:textColor="@color/white"
            android:textSize="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_default="wrap" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.facebook.shimmer.ShimmerFrameLayout>