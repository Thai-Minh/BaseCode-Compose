<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#171717">

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/ad_matrix_native_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/native_headline"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/common_grey_border_8_bg"
                app:layout_constraintEnd_toEndOf="@id/native_media_container_group"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@+id/native_icon_group"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/native_icon_group"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="@+id/native_media_container_group"
                app:layout_constraintEnd_toStartOf="@+id/native_media_container_group"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/native_headline"
                app:layout_constraintVertical_bias="0">

                <View
                    android:id="@+id/native_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/common_grey_border_8_bg"
                    android:scaleType="fitCenter" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/native_media_container_group"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:layout_constraintDimensionRatio="2.3:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="@+id/native_headline"
                app:layout_constraintTop_toTopOf="@+id/native_icon_group">

                <View
                    android:id="@+id/native_media_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/common_grey_border_8_bg"
                    android:scaleType="fitCenter" />

            </androidx.cardview.widget.CardView>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/native_call_to_action"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="10dp"
                android:background="@drawable/common_button_oval"
                android:elevation="0dp"
                android:fontFamily="@font/sf_pro_medium"
                android:gravity="center"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:stateListAnimator="@null"
                android:text="Open"
                android:textColor="@color/white"
                android:textSize="14dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/native_media_container_group"
                app:layout_constraintVertical_bias="0" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.zenith.adapter.ui.AdvertiserView
            android:id="@+id/native_sponsored_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            app:attribution_src="@drawable/ic_ad_top_left" />

    </com.facebook.shimmer.ShimmerFrameLayout>
</RelativeLayout>