<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141414">

    <com.zenith.adapter.ui.AdvertiserView
        android:id="@+id/native_sponsored_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        app:attribution_src="@drawable/ic_ad_top_left"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/native_icon_group"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:visibility="visible"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#0DFFFFFF"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/native_sponsored_layout">

        <com.zenith.adapter.ui.MediaView
            android:id="@+id/native_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0DFFFFFF"
            android:scaleType="fitCenter" />
    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/native_headline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="80dp"
        android:fontFamily="@font/sf_pro_medium"
        android:maxLines="1"
        android:text="Ad"
        android:textColor="#FFFFFF"
        android:textSize="16dp"
        app:layout_constraintBottom_toTopOf="@+id/native_body"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/native_icon_group"
        app:layout_constraintTop_toBottomOf="@+id/native_sponsored_layout" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/native_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/sf_pro_regular"
        android:maxLines="2"
        android:text="Ad"
        android:textColor="#FFFFFF"
        android:textSize="14dp"
        app:layout_constraintBottom_toTopOf="@+id/native_media_container"
        app:layout_constraintEnd_toEndOf="@+id/native_headline"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/native_headline"
        app:layout_constraintTop_toBottomOf="@+id/native_headline"
        app:layout_goneMarginTop="5dp"
        tools:text="Ad Description Text" />

    <com.zenith.adapter.ui.MediaView
        android:id="@+id/native_media_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginVertical="16dp"
        android:background="#0DFFFFFF"
        app:layout_constraintBottom_toTopOf="@id/native_call_to_action"
        app:layout_constraintTop_toBottomOf="@id/native_body" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/native_call_to_action"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/ripple_round_button_gradient"
        android:elevation="0dp"
        android:fontFamily="@font/sf_pro_medium"
        android:gravity="center"
        android:maxLines="1"
        android:minWidth="110dp"
        android:paddingHorizontal="16dp"
        android:stateListAnimator="@null"
        android:text="Open"
        android:textColor="@color/white"
        android:textSize="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_default="wrap" />

</androidx.constraintlayout.widget.ConstraintLayout>